  "designTokenNotes": {
    "colorSystem": "AXIS uses a design-token-driven theming system. All colors are defined as CSS custom properties (--color-*) allowing per-project skinning. The demo environment uses a dark theme with #000 page background, #1a1a1a for navigation and surfaces, #2a2a2a for elevated cards, and #4a6af7 as the brand accent color.",
    "typographySystem": "All typography uses the Inter font family with weight 400 (regular) and 700 (bold). Hero titles use responsive font sizes from 1.125rem (xs) to 4.5rem (xl) with 1.2 line-height. Body text uses 1rem/1.5 standard.",
    "metadataFormatting": "Content metadata (year, duration, rating, genre) is displayed in small (12-14px) pill badges with semi-transparent dark backgrounds (rgba(0,0,0,.4)) and grey borders. Items are separated by 8px margin. The LIVE badge uses a distinctive red (#ec0000) background.",
    "interactionPatterns": "Hover states use the brand blue (#4a6af7) for text and the play icon color #0099f7 for media interactions. Secondary buttons use white borders with transparent backgrounds that get a light overlay on hover."
  }
